# copyright notice and this permission notice appear in all copies.
#
# THE SOFTWARE IS PROVIDED "AS IS" AND THE AUTHOR DISCLAIMS ALL WARRANTIES
# WITH REGARD TO THIS SOFTWARE INCLUDING ALL IMPLIED WARRANTIES OF
# MERCHANTABILITY AND FITNESS. IN NO EVENT SHALL THE AUTHOR BE LIABLE FOR
# ANY SPECIAL, DIRECT, INDIRECT, OR CONSEQUENTIAL DAMAGES OR ANY DAMAGES
# WHATSOEVER RESULTING FROM LOSS OF MIND, USE, DATA OR PROFITS, WHETHER
# IN AN ACTION OF CONTRACT, NEGLIGENCE OR OTHER TORTIOUS ACTION, ARISING
# OUT OF OR IN CONNECTION WITH THE USE OR PERFORMANCE OF THIS SOFTWARE.
#
# museum-trace — capture tmux/zmux wire protocol traces via socket-spy
#
# Usage: museum-trace capture {--zmux|--tmux|--server BIN --client BIN} [--output FILE] [--verbose] [COMMAND [ARGS...]]
#
# Same-implementation (shorthand):
#   museum-trace capture --zmux new-session -d -s test
#   museum-trace capture --tmux new-session -d -s test
#
# Cross-implementation (all four combos):
#   museum-trace capture --server zmux --client tmux list-sessions
#   museum-trace capture --server tmux --client zmux list-sessions
#   museum-trace capture --server zmux --client zmux list-sessions
#   museum-trace capture --server tmux --client tmux list-sessions
#
# Interactive (no command — attaches to the traced session):
#   museum-trace capture --zmux
#   museum-trace capture --zmux --verbose
#
# Options:
#   --verbose   include hex dumps after each decoded message
#   --output F  write trace to F (default: trace-PID.spy-log in cwd)

set -euo pipefail

LAB_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPO_ROOT="$(cd "$LAB_ROOT/.." && pwd)"
SOCKET_SPY="${SOCKET_SPY:-$REPO_ROOT/regress/socket_spy.py}"
ZMUX_BINARY="${ZMUX_BINARY:-$REPO_ROOT/zig-out/bin/zmux}"
TMUX_BINARY="${TMUX_BINARY:-$LAB_ROOT/out/gdb/tmux}"

log() { printf '[museum-trace] %s\n' "$*" >&2; }
die() { log "error: $*"; exit 1; }

usage() {
    sed -n '/^# Usage/,/^$/p' "$0" | sed 's/^# \?//' >&2
    exit "${1:-0}"
}

# Globals for cleanup (set in cmd_capture before trap fires)
SERVER_PID=""
PROXY_PID=""
SERVER_SOCK=""
PROXY_SOCK=""
tmpdir=""

cleanup() {
    # Kill proxy first (so it flushes remaining output)
    if [[ -n "$PROXY_PID" ]]; then
        kill "$PROXY_PID" 2>/dev/null || true
        wait "$PROXY_PID" 2>/dev/null || true
        PROXY_PID=""
    fi
    # Kill server directly by PID (reliable, works cross-implementation)
    if [[ -n "$SERVER_PID" ]]; then
        kill "$SERVER_PID" 2>/dev/null || true
        wait "$SERVER_PID" 2>/dev/null || true
        SERVER_PID=""
    fi
    rm -rf "${tmpdir:-}"
}

resolve_binary() {
    case "$1" in
        zmux) printf '%s' "$ZMUX_BINARY" ;;
        tmux) printf '%s' "$TMUX_BINARY" ;;
        *)    printf '%s' "$1" ;;
    esac
}

cmd_capture() {
    local server_binary="" client_binary="" output="" verbose="" command_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --zmux)
                server_binary="$ZMUX_BINARY"
                client_binary="$ZMUX_BINARY"
                shift ;;
            --tmux)
                server_binary="$TMUX_BINARY"
                client_binary="$TMUX_BINARY"
                shift ;;
            --server)
                server_binary="$(resolve_binary "$2")"
                shift 2 ;;
            --client)
                client_binary="$(resolve_binary "$2")"
                shift 2 ;;
            --output)  output="$2"; shift 2 ;;
            --verbose) verbose=1; shift ;;
            --)        shift; command_args=("$@"); break ;;
            -*)        die "unknown option: $1" ;;
            *)         command_args=("$@"); break ;;
        esac
    done

    [[ -n "$server_binary" ]] || die "specify server: --zmux, --tmux, or --server {zmux|tmux|PATH}"
    [[ -n "$client_binary" ]] || die "specify client: --zmux, --tmux, or --client {zmux|tmux|PATH}"
    [[ -f "$server_binary" ]] || die "server binary not found: $server_binary"
    [[ -f "$client_binary" ]] || die "client binary not found: $client_binary"
    [[ -f "$SOCKET_SPY" ]] || die "socket_spy.py not found: $SOCKET_SPY"

    # Set up temp paths
    tmpdir="/tmp/museum-trace-$$"
    mkdir -p "$tmpdir/bin"
    SERVER_SOCK="$tmpdir/server.sock"
    PROXY_SOCK="$tmpdir/proxy.sock"

    if [[ -z "$output" ]]; then
        output="$(pwd)/trace-$$.spy-log"
    fi

    trap cleanup EXIT INT TERM

    # Derive the server's identity name (tmux or zmux) from its binary path.
    # zmux checks argv[0] to decide protocol conventions, so the client
    # must be invoked with an argv[0] that matches the server's type for
    # cross-implementation combos to work transparently.
    local server_name
    server_name="$(basename "$server_binary")"
    # Normalize: anything that isn't literally "tmux" is treated as zmux
    case "$server_name" in
        tmux) ;;
        *)    server_name="zmux" ;;
    esac

    # Create a symlink so the client binary runs with argv[0] matching
    # the server's identity.  For same-implementation traces this is a
    # harmless no-op; for cross-implementation it makes the client adopt
    # the server's protocol conventions.
    local client_link="$tmpdir/bin/$server_name"
    ln -sf "$client_binary" "$client_link"

    # Start server in foreground mode (-D) so we get the PID directly.
    # Seed it with a detached session so clients have something to attach to.
    log "server: $server_binary ($server_name protocol)"
    log "client: $client_binary (invoked as $server_name)"
    "$server_binary" -D -f/dev/null -S "$SERVER_SOCK" new-session -d -s trace-probe &
    SERVER_PID=$!

    # Poll for server socket (5s timeout)
    local waited=0
    while [[ ! -S "$SERVER_SOCK" ]]; do
        sleep 0.1
        waited=$((waited + 1))
        [[ $waited -lt 50 ]] || die "server socket did not appear after 5s"
    done
    log "server ready: $SERVER_SOCK (pid $SERVER_PID)"

    # Start proxy
    local spy_args=(--listen "$PROXY_SOCK" --connect "$SERVER_SOCK" --output "$output")
    [[ -n "$verbose" ]] && spy_args+=(--verbose)
    python3 "$SOCKET_SPY" "${spy_args[@]}" &
    PROXY_PID=$!

    # Wait for proxy listen socket
    waited=0
    while [[ ! -S "$PROXY_SOCK" ]]; do
        sleep 0.1
        waited=$((waited + 1))
        [[ $waited -lt 30 ]] || die "proxy socket did not appear after 3s"
    done
    log "proxy ready: $PROXY_SOCK"

    # Run client through proxy — invoked via the symlink so
    # argv[0] matches the server's protocol identity.
    # No command args = interactive attach (like bare "tmux").
    if [[ ${#command_args[@]} -gt 0 ]]; then
        log "running: ${command_args[*]}"
        "$client_link" -f/dev/null -S "$PROXY_SOCK" "${command_args[@]}" || true
    else
        log "attaching interactively (detach to finish trace)"
        "$client_link" -f/dev/null -S "$PROXY_SOCK" || true
    fi

    # Kill server directly — reliable regardless of client/server implementation match
    log "stopping server (pid $SERVER_PID)"
    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true
    SERVER_PID=""

    # Give proxy a moment to flush, then collect it
    sleep 0.2
    if [[ -n "$PROXY_PID" ]]; then
        kill "$PROXY_PID" 2>/dev/null || true
        wait "$PROXY_PID" 2>/dev/null || true
        PROXY_PID=""
    fi

    log "trace written: $output"
    printf '%s\n' "$output"
}

# Main dispatch
case "${1:-}" in
    capture) shift; cmd_capture "$@" ;;
    --help|-h|help) usage 0 ;;
    "") usage 1 ;;
    *) die "unknown command: $1 (try --help)" ;;
esac
